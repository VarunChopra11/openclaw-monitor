{
  "version": 2,
  "functions": {
    "api/index.py": {
      "runtime": "vercel-python@4.x",
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "crons": [
    {
      "path": "/api/collect",
      "schedule": "*/30 * * * *"
    }
  ]
}