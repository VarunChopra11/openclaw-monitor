# ── Required ──────────────────────────────────────────────────────────────────
# GitHub Personal Access Token
# Scopes needed: gist (read+write)   +   (public_repo is fine for the GH API reads)
# Create at: https://github.com/settings/tokens/new
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ID of the GitHub Gist used as your snapshot store.
# 1. Go to https://gist.github.com
# 2. Create a NEW secret gist with one file named  snapshots.json  containing just:  {}
# 3. Copy the Gist ID from the URL:  https://gist.github.com/<user>/<GIST_ID>
GIST_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional ──────────────────────────────────────────────────────────────────
# Protect the /api/collect endpoint so only your cron can trigger it.
# Pass as header  X-Secret: <value>  or query param  ?secret=<value>
# Leave empty / unset to allow public access (fine if the endpoint just collects public data)
COLLECT_SECRET=

# Which repo to monitor (default: openclaw/openclaw)
REPO=openclaw/openclaw

# How many snapshots to retain (default: 3  →  last 1.5 hrs at 30-min cadence)
MAX_SNAPSHOTS=3
